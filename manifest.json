{
  "manifest_version": 3,
  "name": "TVING Sports Ad Muter",
  "version": "0.1.0",
  "description": "Auto-mutes the TVING sports broadcast player during ad breaks and restores prior volume when the game resumes.",
  "permissions": ["storage", "activeTab"],
  "host_permissions": ["https://www.tving.com/*"],
  "content_scripts": [
    {
      "matches": ["https://www.tving.com/contents/sports/*/broadcast*"],
      "js": ["content_script.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "TVING Sports Ad Muter",
    "default_icon": {
      "16": "icons/16.png",
      "48": "icons/48.png",
      "128": "icons/128.png"
    }
  },
  "icons": {
    "16": "icons/16.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  }
}
